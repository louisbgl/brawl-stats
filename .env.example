# Brawl Stars API Configuration
# Copy this file to .env and fill in your configuration

# Option 1: Direct API access (requires IP whitelisting)
# Get your token from https://developer.brawlstars.com
BRAWL_STARS_API_TOKEN=your_token_here

# Option 2: Use proxy (no local token needed, proxy handles auth)
# Deploy the proxy/ folder and use its URL
# BRAWL_STARS_PROXY_URL=https://your-proxy.railway.app

# Note: Only ONE of the above is needed
# - For local dev with whitelisted IP: use BRAWL_STARS_API_TOKEN
# - For GitHub Actions / cloud: use BRAWL_STARS_PROXY_URL
